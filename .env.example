# ─── Google ADK / Gemini ──────────────────────────────────
# For AI Studio (local dev):
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# For Vertex AI (production):
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=true

# ─── ADK Model ────────────────────────────────────────────
TRADING_MODEL=gemini-2.0-flash

# ─── News & Sentiment ─────────────────────────────────────
# Free GNews API key → https://gnews.io  (100 req/day free)
# Leave blank to fall back to Google RSS (no key needed)
GNEWS_API_KEY=
NEWS_TIMEOUT_SEC=8

# ─── Screener Research ────────────────────────────────────
SCREENER_EMAIL=your@email.com
SCREENER_PASSWORD=yourpassword

# ─── Broker (Dhan) ────────────────────────────────────────
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# ─── Broker (Zerodha / Kite) ──────────────────────────────
# KITE_API_KEY=your_kite_api_key
# KITE_API_SECRET=your_kite_api_secret
# KITE_ACCESS_TOKEN=your_kite_access_token

# ─── Database ─────────────────────────────────────────────
DB_URL=postgresql+asyncpg://user:password@localhost:5432/trading_db
REDIS_URL=redis://localhost:6379/0

# ─── Risk Parameters ──────────────────────────────────────
MAX_DAILY_LOSS_INR=5000
MAX_POSITION_LOTS=10
MAX_ORDERS_PER_SECOND=10

# ─── WebSocket Feed ───────────────────────────────────────
DHAN_WS_URL=wss://api-feed.dhan.co

# ─── Deployment ───────────────────────────────────────────
ENVIRONMENT=development       # development | production
LOG_LEVEL=INFO
STUB_MODE=true                # true = use stub data (no live broker/news)
